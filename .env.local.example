# Copy to .env.local and fill in. Server-side only — never sent to the browser.
DKAN_MCP_URL=https://dkan-site.ddev.site/mcp
DKAN_OAUTH_TOKEN_URL=https://dkan-site.ddev.site/oauth/token
# ddev's mkcert CA is trusted by the OS but not by Node's bundled store.
DKAN_ALLOW_SELF_SIGNED=1

# Personas: client_credentials consumers on the DKAN site
# (admin/config/services/consumer; see plan's provisioning checklist)
PERSONA_READONLY_CLIENT_ID=inspector-readonly
PERSONA_READONLY_CLIENT_SECRET=
PERSONA_READONLY_SCOPE=dkan_mcp:read

PERSONA_EDITOR_CLIENT_ID=inspector-editor
PERSONA_EDITOR_CLIENT_SECRET=
PERSONA_EDITOR_SCOPE=dkan_mcp:write

# Agent mode
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
